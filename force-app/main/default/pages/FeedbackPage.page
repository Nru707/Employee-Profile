<apex:page controller="PublicFeedbackController"
    showHeader="false"
    sidebar="false"
    standardStylesheets="false"
    applyBodyTag="false"
    docType="html-5.0"
    action="{!initPage}">

<html lang="en">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Product Feedback</title>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: Arial, sans-serif;
            background: #f3f4f6;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            padding: 2rem 1rem;
        }

        .feedback-card {
            background: #fff;
            border-radius: 14px;
            box-shadow: 0 6px 32px rgba(0,0,0,0.11);
            width: 100%;
            max-width: 820px;
            height: fit-content;
            overflow: hidden;
        }

        .form-header {
            background: linear-gradient(135deg, #0176d3 0%, #014486 100%);
            padding: 2rem 2.5rem;
            text-align: center;
            color: #fff;
        }
        .header-icon   { font-size: 2.8rem; margin-bottom: 0.5rem; }
        .form-title    { font-size: 1.8rem; font-weight: 800; margin-bottom: 0.25rem; }
        .form-subtitle { font-size: 1rem; opacity: 0.9; }
        .form-account  { font-size: 0.85rem; opacity: 0.72; }

        .opp-banner {
            display: flex;
            background: #f8fafc;
            border-bottom: 1px solid #e4e6e9;
        }
        .opp-detail {
            flex: 1; padding: 1rem 1.5rem;
            display: flex; flex-direction: column; gap: 0.2rem;
            border-right: 1px solid #e4e6e9;
        }
        .opp-detail:last-child { border-right: none; }
        .opp-label { font-size: 0.72rem; font-weight: 700; color: #706e6b; text-transform: uppercase; letter-spacing: 0.05em; }
        .opp-value { font-size: 0.92rem; font-weight: 700; color: #1b1b1b; }
        .stage-won { color: #2e844a; }

        .form-body { padding: 2rem 2.5rem; display: flex; flex-direction: column; gap: 1.4rem; }

        .section-divider {
            font-size: 0.78rem; font-weight: 800; color: #0176d3;
            text-transform: uppercase; letter-spacing: 0.07em;
            border-bottom: 2px solid #e8f4fd; padding-bottom: 0.35rem;
        }

        .field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }
        .field-group { display: flex; flex-direction: column; gap: 0.35rem; }
        .field-label { font-size: 0.83rem; font-weight: 700; color: #3e3e3c; }
        .required { color: #ea001e; }

        input[type=text], input[type=email], input[type=date],
        input[type=number], select, textarea {
            width: 100%; padding: 0.6rem 0.85rem;
            border: 1.5px solid #dddbda; border-radius: 6px;
            font-size: 0.9rem; font-family: inherit;
            color: #3e3e3c; background: #fff; outline: none;
        }
        input:focus, select:focus, textarea:focus {
            border-color: #0176d3;
            box-shadow: 0 0 0 3px rgba(1,118,211,0.13);
        }
        textarea { resize: vertical; min-height: 100px; }

        .star-row { display: flex; align-items: center; gap: 0.2rem; flex-wrap: wrap; }
        .star {
            font-size: 2.4rem; color: #dddbda;
            cursor: pointer; background: none; border: none;
            padding: 0 2px; line-height: 1;
        }
        .star.active { color: #f8a200; }
        .rating-text { font-size: 0.85rem; color: #706e6b; font-weight: 700; margin-left: 0.5rem; }

        .nps-labels { display: flex; justify-content: space-between; font-size: 0.78rem; color: #706e6b; margin-bottom: 0.4rem; }
        .nps-row { display: flex; gap: 0.35rem; flex-wrap: wrap; }
        .nps-btn {
            width: 44px; height: 44px;
            border: 1.5px solid #dddbda; border-radius: 8px;
            background: #fff; font-size: 0.88rem; font-weight: 700;
            color: #3e3e3c; cursor: pointer;
        }
        .nps-btn.sel { background: #0176d3; border-color: #0176d3; color: #fff; }

        .dyn-field { display: flex; flex-direction: column; gap: 0.35rem; }

        .error-banner {
            background: #fef1ee; border: 1px solid #ea001e;
            border-radius: 6px; padding: 0.75rem 1rem;
            color: #ba0517; font-size: 0.875rem; font-weight: 600;
            display: none;
        }

        .form-footer { display: flex; justify-content: flex-end; gap: 1rem; padding-top: 1rem; border-top: 1px solid #f0f0f0; }
        .btn { padding: 0.62rem 1.6rem; border-radius: 6px; font-size: 0.9rem; font-weight: 700; font-family: inherit; cursor: pointer; border: none; }
        .btn-neutral { background: #fff; border: 1.5px solid #dddbda; color: #3e3e3c; }
        .btn-brand   { background: #0176d3; color: #fff; }

        .state-screen {
            display: flex; flex-direction: column; align-items: center;
            padding: 4rem 2rem; gap: 1rem; text-align: center;
        }
        .success-circle {
            width: 72px; height: 72px; background: #2e844a;
            border-radius: 50%; display: flex; align-items: center;
            justify-content: center; font-size: 2.4rem; color: #fff; font-weight: bold;
        }
        .success-title { font-size: 1.6rem; font-weight: 800; color: #2e844a; }
        .feedback-id   { font-size: 0.82rem; color: #706e6b; }
        .error-title   { font-size: 1.4rem; font-weight: 800; color: #ba0517; }
        .char-count { text-align: right; font-size: 0.77rem; color: #706e6b; margin-top: 0.2rem; }

        @media(max-width:620px){
            .field-row { grid-template-columns: 1fr; }
            .form-body, .form-header { padding: 1.4rem; }
            .opp-banner { flex-direction: column; }
            .opp-detail { border-right: none; border-bottom: 1px solid #e4e6e9; }
            .nps-btn { width: 36px; height: 36px; font-size: 0.78rem; }
        }
    </style>
</head>
<body>
<div class="feedback-card">

    <!-- INVALID LINK -->
    <apex:outputPanel rendered="{!isInvalidLink}">
        <div class="state-screen">
            <div style="font-size:3rem">&#9888;&#65039;</div>
            <div class="error-title">Invalid Link</div>
            <p style="color:#706e6b;">This feedback link is invalid or expired. Please use the link from your email.</p>
        </div>
    </apex:outputPanel>

    <!-- ALREADY SUBMITTED -->
    <apex:outputPanel rendered="{!alreadySubmitted}">
        <div class="state-screen">
            <div class="success-circle" style="background:#706e6b">&#10003;</div>
            <div class="success-title" style="color:#706e6b">Already Submitted</div>
            <p style="color:#706e6b;">Feedback for this opportunity has already been recorded. Thank you!</p>
        </div>
    </apex:outputPanel>

    <!-- SUCCESS -->
    <apex:outputPanel rendered="{!isSubmitted}">
        <div class="state-screen">
            <div class="success-circle">&#10003;</div>
            <div class="success-title">Thank You!</div>
            <p>Your feedback for <strong><apex:outputText value="{!opportunityName}"/></strong> has been submitted.</p>
            <p class="feedback-id">Feedback ID: <apex:outputText value="{!submittedFeedbackId}"/></p>
        </div>
    </apex:outputPanel>

    <!-- MAIN FORM -->
    <apex:outputPanel rendered="{!showForm}">

        <div class="form-header">
            <div class="header-icon">&#128203;</div>
            <div class="form-title">Product Feedback</div>
            <div class="form-subtitle"><apex:outputText value="{!opportunityName}"/></div>
            <div class="form-account"><apex:outputText value="{!accountName}"/></div>
        </div>

        <div class="opp-banner">
            <div class="opp-detail">
                <span class="opp-label">Owner</span>
                <span class="opp-value"><apex:outputText value="{!ownerName}"/></span>
            </div>
            <div class="opp-detail">
                <span class="opp-label">Close Date</span>
                <span class="opp-value"><apex:outputText value="{!closeDate}"/></span>
            </div>
            <div class="opp-detail">
                <span class="opp-label">Stage</span>
                <span class="opp-value stage-won">&#10003; Closed Won</span>
            </div>
        </div>

        <apex:form id="mainForm">

            <apex:inputHidden value="{!starRating}"           id="starRatingField"/>
            <apex:inputHidden value="{!npsScore}"             id="npsScoreField"/>
            <apex:inputHidden value="{!dynamicResponsesJSON}" id="dynResponsesField"/>

            <!-- Name hidden to pass value -->
            <apex:inputHidden value="{!respondentName}"  id="nameHidden"/>
            <apex:inputHidden value="{!respondentEmail}" id="emailHidden"/>
            <apex:inputHidden value="{!feedbackDate}"    id="dateHidden"/>
            <apex:inputHidden value="{!subject}"         id="subjectHidden"/>
            <apex:inputHidden value="{!comments}"        id="commentsHidden"/>
            <apex:inputHidden value="{!improvementSuggestions}" id="suggestionsHidden"/>

            <div class="form-body">

                <!-- Basic Info -->
                <div class="section-divider">Basic Information</div>
                <div class="field-row">
                    <div class="field-group">
                        <label class="field-label">Your Name <span class="required">*</span></label>
                        <input type="text" id="nameInput" class="txt-input"
                            placeholder="Enter your full name"
                            value="{!respondentName}"
                            oninput="syncHidden(this, '{!$Component.mainForm.nameHidden}')"/>
                    </div>
                    <div class="field-group">
                        <label class="field-label">Your Email <span class="required">*</span></label>
                        <input type="email" id="emailInput" class="txt-input"
                            placeholder="Enter your email"
                            value="{!respondentEmail}"
                            oninput="syncHidden(this, '{!$Component.mainForm.emailHidden}')"/>
                    </div>
                </div>

                <div class="field-row">
                    <div class="field-group">
                        <label class="field-label">Feedback Date <span class="required">*</span></label>
                        <input type="date" id="dateInput" class="txt-input"
                            value="{!feedbackDate}"
                            onchange="syncHidden(this, '{!$Component.mainForm.dateHidden}')"/>
                    </div>
                    <div class="field-group">
                        <label class="field-label">Subject / Topic <span class="required">*</span></label>
                        <select id="subjectInput" class="txt-input"
                            onchange="syncHidden(this, '{!$Component.mainForm.subjectHidden}')">
                            <option value="">-- Select a topic --</option>
                            <option value="Product Quality">Product Quality</option>
                            <option value="Product Features">Product Features</option>
                            <option value="Pricing and Value">Pricing and Value</option>
                            <option value="Ease of Use">Ease of Use</option>
                            <option value="Customer Support">Customer Support</option>
                            <option value="Delivery and Packaging">Delivery and Packaging</option>
                            <option value="Other">Other</option>
                        </select>
                    </div>
                </div>

                <!-- Ratings -->
                <div class="section-divider">Ratings</div>

                <div class="field-group">
                    <label class="field-label">Overall Rating <span class="required">*</span></label>
                    <div class="star-row">
                        <button type="button" class="star" data-v="1" onclick="handleStar(1)">&#9733;</button>
                        <button type="button" class="star" data-v="2" onclick="handleStar(2)">&#9733;</button>
                        <button type="button" class="star" data-v="3" onclick="handleStar(3)">&#9733;</button>
                        <button type="button" class="star" data-v="4" onclick="handleStar(4)">&#9733;</button>
                        <button type="button" class="star" data-v="5" onclick="handleStar(5)">&#9733;</button>
                        <span class="rating-text" id="ratingText">Select a rating</span>
                    </div>
                </div>

                <div class="field-group">
                    <label class="field-label">How likely to recommend us? (0-10) <span class="required">*</span></label>
                    <div class="nps-labels"><span>Not likely</span><span>Very likely</span></div>
                    <div class="nps-row" id="npsRow"></div>
                </div>

                <!-- Dynamic Questions -->
                <apex:outputPanel rendered="{!hasDynamicQuestions}">
                    <apex:repeat value="{!sectionLabels}" var="section">
                        <div class="section-divider"><apex:outputText value="{!section}"/></div>
                        <apex:repeat value="{!questionsBySection[section]}" var="q">
                            <div class="dyn-field" style="margin-bottom:1.2rem;">
                                <label class="field-label">
                                    <apex:outputText value="{!q.questionText}"/>
                                    <apex:outputPanel rendered="{!q.isRequired}">
                                        <span class="required"> *</span>
                                    </apex:outputPanel>
                                </label>
                                <apex:outputPanel rendered="{!q.isText}">
                                    <input type="text" class="dyn-input" data-qid="{!q.id}"
                                        placeholder="{!q.placeholder}" oninput="saveDyn(this)"/>
                                </apex:outputPanel>
                                <apex:outputPanel rendered="{!q.isLongText}">
                                    <textarea class="dyn-input" data-qid="{!q.id}"
                                        placeholder="{!q.placeholder}" rows="3"
                                        oninput="saveDyn(this)"></textarea>
                                </apex:outputPanel>
                                <apex:outputPanel rendered="{!q.isNumber}">
                                    <input type="number" class="dyn-input" data-qid="{!q.id}"
                                        placeholder="{!q.placeholder}" oninput="saveDyn(this)"/>
                                </apex:outputPanel>
                                <apex:outputPanel rendered="{!q.isDate}">
                                    <input type="date" class="dyn-input" data-qid="{!q.id}"
                                        onchange="saveDyn(this)"/>
                                </apex:outputPanel>
                                <apex:outputPanel rendered="{!q.isPicklist}">
                                    <select class="dyn-input" data-qid="{!q.id}" onchange="saveDyn(this)">
                                        <option value="">-- Select --</option>
                                        <apex:repeat value="{!q.picklistOptions}" var="opt">
                                            <option value="{!opt}"><apex:outputText value="{!opt}"/></option>
                                        </apex:repeat>
                                    </select>
                                </apex:outputPanel>
                            </div>
                        </apex:repeat>
                    </apex:repeat>
                </apex:outputPanel>

                <!-- Comments -->
                <div class="section-divider">Your Thoughts</div>
                <div class="field-group">
                    <label class="field-label">Your Feedback <span class="required">*</span></label>
                    <textarea id="commentsInput" class="txt-input" rows="4"
                        placeholder="Share your experience..." maxlength="1000"
                        oninput="updateCharCount(this, 'charCount1'); syncHidden(this, '{!$Component.mainForm.commentsHidden}')"></textarea>
                    <div class="char-count"><span id="charCount1">0</span>/1000</div>
                </div>

                <div class="field-group">
                    <label class="field-label">Improvement Suggestions</label>
                    <textarea id="suggestionsInput" class="txt-input" rows="3"
                        placeholder="Any suggestions to improve?" maxlength="1000"
                        oninput="syncHidden(this, '{!$Component.mainForm.suggestionsHidden}')"></textarea>
                </div>

                <!-- Error -->
                <div class="error-banner" id="errorBanner">
                    &#9888; <span id="errorMsg"></span>
                </div>

                <!-- Footer -->
                <div class="form-footer">
                    <button type="button" class="btn btn-neutral" onclick="clearForm()">Clear</button>
                    <apex:commandButton value="Submit Feedback"
                        action="{!submitFeedback}"
                        styleClass="btn btn-brand"
                        onclick="return validateForm();"
                        />
                </div>

            </div>
        </apex:form>
    </apex:outputPanel>

</div>

<script>
    // ── Sync plain input to hidden apex field ──
    function syncHidden(el, hiddenId) {
        var hidden = document.getElementById(hiddenId);
        if (hidden) hidden.value = el.value;
    }

    // ── Stars ──
    var starRating = 0;
    var ratingLabels = ['','Poor','Fair','Good','Very Good','Excellent'];
    var stars = document.querySelectorAll('.star');

    function handleStar(val) {
        starRating = val;
        renderStars(val);
        document.getElementById('{!$Component.mainForm.starRatingField}').value = val;
    }
    function renderStars(val) {
        stars.forEach(function(s) {
            s.classList.toggle('active', parseInt(s.dataset.v) <= val);
        });
        document.getElementById('ratingText').textContent = val ? ratingLabels[val] : 'Select a rating';
    }
    stars.forEach(function(s) {
        s.addEventListener('mouseenter', function() { renderStars(parseInt(s.dataset.v)); });
        s.addEventListener('mouseleave', function() { renderStars(starRating); });
    });

    // ── NPS ──
    var npsScore = null;
    var npsRow = document.getElementById('npsRow');
    for (var i = 0; i <= 10; i++) {
        (function(val) {
            var b = document.createElement('button');
            b.type = 'button';
            b.className = 'nps-btn';
            b.textContent = val;
            b.onclick = function() {
                npsScore = val;
                document.querySelectorAll('.nps-btn').forEach(function(x) {
                    x.classList.toggle('sel', parseInt(x.textContent) === val);
                });
                document.getElementById('{!$Component.mainForm.npsScoreField}').value = val;
            };
            npsRow.appendChild(b);
        })(i);
    }

    // ── Dynamic Responses ──
    var dynResponses = {};
    function saveDyn(el) {
        dynResponses[el.dataset.qid] = el.value;
        document.getElementById('{!$Component.mainForm.dynResponsesField}').value = JSON.stringify(dynResponses);
    }

    // ── Char Count ──
    function updateCharCount(el, countId) {
        document.getElementById(countId).textContent = el.value.length;
    }

    // ── Validation ── (plain JS inputs use kiye hain — direct value milegi)
    function validateForm() {
        hideError();

        var name     = document.getElementById('nameInput');
        var email    = document.getElementById('emailInput');
        var subject  = document.getElementById('subjectInput');
        var date     = document.getElementById('dateInput');
        var comments = document.getElementById('commentsInput');

        if (!name.value.trim())                                  return showError('Please enter your name.');
        if (!email.value.trim() || !email.value.includes('@'))   return showError('Please enter a valid email.');
        if (!subject.value)                                      return showError('Please select a subject/topic.');
        if (!date.value)                                         return showError('Please select a feedback date.');
        if (!starRating)                                         return showError('Please provide a star rating.');
        if (npsScore === null)                                   return showError('Please select an NPS score.');
        if (!comments.value.trim())                              return showError('Please enter your feedback.');
        return true;
    }

    function showError(msg) {
        var b = document.getElementById('errorBanner');
        document.getElementById('errorMsg').textContent = msg;
        b.style.display = 'block';
        b.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        return false;
    }
    function hideError() {
        document.getElementById('errorBanner').style.display = 'none';
    }

    // ── Clear ──
    function clearForm() {
        document.getElementById('nameInput').value       = '';
        document.getElementById('emailInput').value      = '';
        document.getElementById('dateInput').value       = '';
        document.getElementById('subjectInput').value    = '';
        document.getElementById('commentsInput').value   = '';
        document.getElementById('suggestionsInput').value= '';
        document.querySelectorAll('.dyn-input').forEach(function(el) { el.value = ''; });
        starRating = 0; renderStars(0);
        npsScore = null;
        document.querySelectorAll('.nps-btn').forEach(function(b) { b.classList.remove('sel'); });
        dynResponses = {};
        document.getElementById('charCount1').textContent = '0';
        hideError();
    }
</script>
</body>
</html>
</apex:page>